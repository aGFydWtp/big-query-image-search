# image-search-api environment variables (EXAMPLE — placeholders only).
#
# Copy to a local .env for development, or use as the reference set for the
# Cloud Run service definition (deploy/service.yaml). Replace every *_PLACEHOLDER
# with a real value at deploy time. This committed example MUST NOT contain real
# project ids, bucket names, dataset ids, or service account emails.
#
# Provenance (see .kiro/specs/image-search-api/design.md "Allowed Dependencies"):
#   upstream gcp-infrastructure `terraform output` and the image-ingestion-pipeline
#   shared contract.

# --- Required ---

# GCP project id (deployment target).
PROJECT_ID=PROJECT_ID_PLACEHOLDER

# BigQuery / GCS / remote-model location. Fixed single-region value.
# Source: gcp-infrastructure input variable (no terraform output for region).
REGION=us-central1

# Project-qualified BigQuery dataset, e.g. "project.dataset".
# Source: gcp-infrastructure output bigquery_dataset_id.
DATASET_ID=DATASET_ID_PLACEHOLDER

# Embeddings table name (shared contract from image-ingestion-pipeline).
EMBEDDINGS_TABLE=image_embeddings

# Target GCS bucket for signed URLs.
# Source: gcp-infrastructure output image_bucket_name.
IMAGE_BUCKET=IMAGE_BUCKET_PLACEHOLDER

# Cloud Run runtime service account email; also the GoogleAccessID for signed URLs.
# Source: gcp-infrastructure output cloud_run_service_account_email.
RUN_SA_EMAIL=RUN_SA_EMAIL_PLACEHOLDER

# --- Optional (have code defaults) ---

# Remote model OBJECT name. This is the object name gemini_embedding_model
# created by the ingestion side — NOT the endpoint name gemini-embedding-2-preview.
# Defaults to gemini_embedding_model when unset.
MODEL=gemini_embedding_model

# Signed URL validity as a Go duration (e.g. 15m). Defaults to 15m when unset.
SIGNED_URL_EXPIRY=15m

# PORT is injected by Cloud Run at runtime (default 8080 for local runs); do not
# set it in the service definition.
# PORT=8080
